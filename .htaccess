# ----------------------------------------------------------------------
# PhysioGlides Hardened Production Server Configuration (.htaccess)
# Designed for Hostinger Shared Apache Web Server Environments
# ----------------------------------------------------------------------

# 1. Prevent Directory Index Listing
Options -Indexes

# 2. Block Web Access to Critical System Files, Scripts, and Credentials
<FilesMatch "^\.|\.(sql|ini|log|config\.php|config\.example\.php|cleanup\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Allow access to cleanup.php for CLI cron execution, but protect web execution via token verification
<Files "cleanup.php">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Allow from all
    </IfModule>
</Files>

# 3. Force Secure SSL Redirection
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# 4. Enable Gzip Compression for Performance (mod_deflate)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# 5. Enable Browser Cache Controls (mod_expires)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    # Fonts
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    
    # Images & WebP
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    
    # Styles & Logic
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
</IfModule>

# 6. Apply Security Headers (mod_headers)
<IfModule mod_headers.c>
    # Restrict iframe embedding to own domain
    Header set X-Frame-Options "SAMEORIGIN"
    
    # Block mime sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Referrer configuration
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Moderately hardened Content Security Policy
    # Allows desafíos (Turnstile script, frame validation, maps, and local fonts)
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://challenges.cloudflare.com; frame-src 'self' https://challenges.cloudflare.com https://www.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://challenges.cloudflare.com;"
</IfModule>
